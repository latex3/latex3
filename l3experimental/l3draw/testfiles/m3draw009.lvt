\docouemntclass{minimal}

\input{regression-test}
\RequirePackage{l3draw}

\begin{document}

\START
\AUTHOR{peaR}

\ExplSyntaxOn
\cs_new_protected:Npn \test_draw_part:n #1 {
    \draw_scope_begin:
        \draw_transform_shift:n {#1}
        \draw_layer_begin:n { background }
            \color_select:n { blue }
            \draw_path_circle:nn { 0 , 0 } { 1cm }
            \draw_path_use_clear:n { fill }
        \draw_layer_end:
        \hcoffin_set:Nn \l_tmpa_coffin {
            \draw_suspend_begin:
                \draw_begin:
                    \color_select:n { red }
                    \draw_path_circle:nn { 0 , 0 } { 10pt }
                    \draw_path_use_clear:n { fill }
                \draw_end:
            \draw_suspend_end:
        }
        \draw_coffin_use:Nnnn \l_tmpa_coffin { hc } { vc } { 0 , 0 }
    \draw_scope_end:
}

\hbox_set:Nn \l_tmpa_box
  {
    \draw_begin:
      \draw_layer_new:n { background }
      \clist_set:Nn \l_draw_layers_clist { background , main }
      \test_draw_part:n { 0cm , 0cm }
      \test_draw_part:n { 3cm , 0cm }
    \draw_end:
  }
\box_show:N \l_tmpa_box
\ExplSyntaxOff

\END

