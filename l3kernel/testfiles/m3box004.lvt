\documentclass{minimal}
\input{regression-test}
\ExplSyntaxOn
\debug_on:n { check-declarations , deprecation , log-functions }
\ExplSyntaxOff

\begin{document}

\START
\AUTHOR{Joseph Wright}
\ExplSyntaxOn
\showoutput

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\TEST { Make~a~box~as~an~argument }
  {
    Hello~world
    \vbox:n { \hbox:n { Fragile! } }
    \vbox_top:n { \hbox:n { Fragile! } }
    \vbox_center:n { \hbox:n { Fragile! } }
    \vbox_to_ht:nn { 30pt } { \hbox:n { Fragile! } }
    \vbox_top_to_ht:nn { 30pt } { \hbox:n { Fragile! } }
    \vbox_center_to_ht:nn { 30pt } { \hbox:n { Fragile! } }
  }

\par

\TEST { Make~a~box~without~grabbing }
  {
    Hello~world
    \vbox:w \hbox:n { Fragile! } \vbox_end:
    \vbox_top:w \hbox:n { Fragile! } \vbox_end:
    \vbox_center:w \hbox:n { Fragile! } \vbox_end:
    \vbox_to_ht:nw { 30pt } \hbox:n { Fragile! } \vbox_end:
    \vbox_top_to_ht:nw { 30pt } \hbox:n { Fragile! } \vbox_end:
    \vbox_center_to_ht:nw { 30pt } \hbox:n { Fragile! } \vbox_end:
  }

\par

\TEST { Make~an~offset~box~as~an~argument }
  {
    Hello~world
    \vbox:nn { 10pt } { \hbox:n { Fragile! } }
    \vbox_top:nn { 10pt } { \hbox:n { Fragile! } }
    \vbox_center:nn { 10pt } { \hbox:n { Fragile! } }
    \vbox_to_ht:nnn { 30pt } { 10pt } { \hbox:n { Fragile! } }
    \vbox_top_to_ht:nnn { 30pt } { 10pt } { \hbox:n { Fragile! } }
    \vbox_center_to_ht:nnn { 30pt } { 10pt } { \hbox:n { Fragile! } }
  }

\par

\TEST { Make~an~offset~box~without~grabbing }
  {
    Hello~world
    \vbox:nw { 10pt } \hbox:n { Fragile! } \vbox_end:
    \vbox_top:nw { 10pt } \hbox:n { Fragile! } \vbox_end:
    \vbox_center:nw { 10pt } \hbox:n { Fragile! } \vbox_end:
    \vbox_to_ht:nnw { 30pt } { 10pt } \hbox:n { Fragile! } \vbox_end:
    \vbox_top_to_ht:nnw { 30pt } { 10pt } \hbox:n { Fragile! } \vbox_end:
    \vbox_center_to_ht:nnw { 30pt } { 10pt } \hbox:n { Fragile! } \vbox_end:
  }

\END
