\input{regression-test}

\ExplSyntaxOn
\debug_on:n { check-declarations , deprecation , log-functions }
\ExplSyntaxOff

\ExplSyntaxOn

\START

\TESTEXP { Simple~BCP~47~parsing }
  {
    \text_bcp_parse:n { en }
    \NEWLINE
    \text_bcp_parse:n { en-GB }
    \NEWLINE
    \text_bcp_parse:n { en-Latn-GB }
    \NEWLINE
    \text_bcp_parse:n { en-abc }
    \NEWLINE
    \text_bcp_parse:n { en-abc-def }
    \NEWLINE
    \text_bcp_parse:n { en-abc-def-ghi }
    \NEWLINE
    \text_bcp_parse:n { es-419 }
    \NEWLINE
    \text_bcp_parse:n { rm-sursilv }
    \NEWLINE
    \text_bcp_parse:n { sr-Cyrl }
    \NEWLINE
    \text_bcp_parse:n { nan-Hant-TW }
    \NEWLINE
    \text_bcp_parse:n { yue-Hant-HK }
    \NEWLINE
    \text_bcp_parse:n { en-t-jp }
    \NEWLINE
    \text_bcp_parse:n { ar-u-nu-latn }
    \NEWLINE
    \text_bcp_parse:n { he-IL-u-ca-hebrew-tz-jeruslm }
    \NEWLINE
    \text_bcp_parse:n { gsw-u-sd-chzh }
    \NEWLINE
    \text_bcp_parse:n { de-x-eszett }
  }

\TESTEXP { Invalid~BCP~47~input }
  {
    \text_bcp_parse:n { }
    \NEWLINE
    \text_bcp_parse:n { en-abc-def-ghi-jkl }
    \NEWLINE
    \text_bcp_parse:n { en-u }
    \NEWLINE
    \text_bcp_parse:n { en-u-XXX-u-yyy }
    \NEWLINE
    \text_bcp_parse:n { en-u-XXX-t-yyy-U-zzz }
  }

\END