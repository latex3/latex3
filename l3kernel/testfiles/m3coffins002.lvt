\documentclass{minimal}
\input{regression-test}

\ExplSyntaxOn
\coffin_new:N \test_temp_coffin
\coffin_new:N \l_list_coffin
\coffin_new:N \l_temp_item_coffin

\cs_new_protected_nopar:Npn \test_coffin_display_handles:Nnnn #1#2#3#4
  {
    \coffin_show_structure:N #1
    \coffin_show:Nnn #1 {5} {2}
    \iow_term:x { ~ }
  }

\cs_new:Npn \test_store_item:
  {
    \dim_compare:nNnTF { \coffin_ht:N \l_list_coffin } = { 0pt }
      {
        \coffin_set_eq:NN \l_list_coffin \l_temp_item_coffin
      }
      {
        \coffin_join:NnnNnnnn
          \l_list_coffin {B} {l}
          \l_temp_item_coffin {T} {l}
          {0pt} { -\baselineskip }
      }
    \test_coffin_display_handles:Nnnn \l_list_coffin {l,r} {B,T} { red }
  }

\cs_new:Npn \test_make_item:nn #1#2
  {
    \vcoffin_set:Nnn \l_temp_item_coffin {5cm} { #1 }
    \vcoffin_set:Nnn \l_tmpa_coffin {5cm} { #2 }
    \coffin_join:NnnNnnnn
      \l_temp_item_coffin {B} {l}
      \l_tmpa_coffin {T} {l}
      {0pt} { -\baselineskip }
    \test_store_item:
  }
\ExplSyntaxOff

