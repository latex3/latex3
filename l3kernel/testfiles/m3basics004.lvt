%

\documentclass{minimal}
\input{regression-test}

\START
\AUTHOR{Vit Stary Novotny, Joseph Wright}
\ExplSyntaxOn

\OMIT
\cs_new:Npn
  \make_assertions:
  {
    \debug_assert:nn  { mypkg } { \c_false_bool }
    \debug_assert:nN  { mypkg }   \c_false_bool
    \debug_assert:nnn { mypkg } { \c_false_bool } { Shut~her~down,~Clancy! }
    \debug_assert:nNn { mypkg }   \c_false_bool   { She's~pumping~mud! }
    \debug_assert:nn  { mypkg } { \c_true_bool }
    \debug_assert:nN  { mypkg }   \c_true_bool
    \debug_assert:nnn { mypkg } { \c_true_bool }  { Shut~her~down~Scotty! }
    \debug_assert:nNn { mypkg }   \c_true_bool    { She's~sucking~mud~again! }
  }
\TIMO

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\TESTEXP { Assertions~are~unchecked~by~default }
  {
    \make_assertions:
  }

\debug_on:n { check-assertions }
\TESTEXP { Enabling~the~checking~of~assertions,~check-assertions }
  {
    \make_assertions:
  }

\debug_off:n { check-assertions }
\TESTEXP { Enabling~and~disabling~the~checking~of~assertions,~check-assertions }
  {
    \make_assertions:
  }

\debug_on:n { all }
\TESTEXP { Enabling~the~checking~of~assertions,~all }
  {
    \make_assertions:
  }

\debug_off:n { all }
\TESTEXP { Enabling~and~disabling~the~checking~of~assertions,~all }
  {
    \make_assertions:
  }

\debug_on:n { check-assertions }
\debug_suspend:
\TESTEXP { Enabling~and~suspending~the~checking~of~assertions,~check-assertions }
  {
    \make_assertions:
  }
\debug_resume:
\debug_off:n { check-assertions }

\debug_on:n { all }
\debug_suspend:
\TESTEXP { Enabling~and~suspending~the~checking~of~assertions,~all }
  {
    \make_assertions:
  }
\debug_resume:
\debug_off:n { all }

\debug_on:n { check-assertions }
\debug_suspend:
\debug_resume:
\TESTEXP { Enabling,~suspending,~and~resuming~the~checking~of~assertions,~check-assertions }
  {
    \make_assertions:
  }
\debug_off:n { check-assertions }

\debug_on:n { all }
\debug_suspend:
\debug_resume:
\TESTEXP { Enabling,~suspending,~and~resuming~the~checking~of~assertions,~all }
  {
    \make_assertions:
  }
\debug_off:n { all }

\END
