%

\documentclass{minimal}
\input{regression-test}



% Leave some padding so that the line numbers
% of the tests don't change later on.



\START
\AUTHOR{Vit Stary Novotny}
\ExplSyntaxOn

\OMIT
\cs_new:Npn
  \make_assertions:
  {
    \debug_assert:nn  { mypkg } { \c_false_bool }
    \debug_assert:nN  { mypkg }   \c_false_bool
    \debug_assert:nnn { mypkg } { \c_false_bool } { Shut~her~down,~Clancy! }
    \debug_assert:nNn { mypkg }   \c_false_bool   { She's~pumping~mud! }
    \debug_assert:nn  { mypkg } { \c_true_bool }
    \debug_assert:nN  { mypkg }   \c_true_bool
    \debug_assert:nnn { mypkg } { \c_true_bool }  { Shut~her~down~Scotty! }
    \debug_assert:nNn { mypkg }   \c_true_bool    { She's~sucking~mud~again! }
  }
\TIMO

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\TEST { Assertions~are~unchecked~by~default }
  {
    \make_assertions:
  }

\TEST { Enabling~the~checking~of~assertions,~check-assertions }
  {
    \debug_on:n { check-assertions }
    \make_assertions:
    \debug_off:n { check-assertions }
  }

\TEST { Enabling~the~checking~of~assertions,~all }
  {
    \debug_on:n { all }
    \make_assertions:
    \debug_off:n { all }
  }

\TEST { Enabling~and~disabling~the~checking~of~assertions,~check-assertions }
  {
    \debug_on:n { check-assertions }
    \debug_off:n { check-assertions }
    \make_assertions:
  }

\TEST { Enabling~and~disabling~the~checking~of~assertions,~all }
  {
    \debug_on:n { all }
    \debug_off:n { all }
    \make_assertions:
  }

\TEST { Enabling~and~suspending~the~checking~of~assertions,~check-assertions }
  {
    \debug_on:n { check-assertions }
    \debug_suspend:
    \make_assertions:
    \debug_resume:
    \debug_off:n { check-assertions }
  }

\TEST { Enabling~and~suspending~the~checking~of~assertions,~all }
  {
    \debug_on:n { all }
    \debug_suspend:
    \make_assertions:
    \debug_resume:
    \debug_off:n { all }
  }

\TEST { Enabling,~suspending,~and~resuming~the~checking~of~assertions,~check-assertions }
  {
    \debug_on:n { check-assertions }
    \debug_suspend:
    \debug_resume:
    \make_assertions:
    \debug_off:n { check-assertions }
  }

\TEST { Enabling,~suspending,~and~resuming~the~checking~of~assertions,~all }
  {
    \debug_on:n { all }
    \debug_suspend:
    \debug_resume:
    \make_assertions:
    \debug_off:n { all }
  }

\END
