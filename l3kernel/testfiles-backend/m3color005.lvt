\documentclass{minimal}

\input{regression-test}

\ExplSyntaxOn
\sys_ensure_backend:
\debug_on:n { check-declarations , deprecation , log-functions }
\ExplSyntaxOff

\START

\AUTHOR{Joseph Wright}

\ExplSyntaxOn

\OMIT
  \cs_set_protected:Npn \test:n #1
    {
      \hbox_set:Nn \l_tmpa_box
        {
          #1
          Hello
        }
      \box_show:N \l_tmpa_box
    }
\TIMO

\TEST { Current~color }
  {
    \test:n { \color_ensure_current: }
  }

\makeatletter

\OMIT
\color_model_new:nnn { pantone1215 }
  { Separation }
  {
    name = PANTONE~1215~U ,
    alternative-model = cmyk ,
    alternative-values = {0, 0.15, 0.51, 0}
  }
\color_set:nnn { spotA } { pantone1215 } { 1 }
\TIMO

\TEST { Setting~\current@color }
  {
    \color_select:n { cyan }
    \cs_show:N \current@color
    \color_select:n { red }
    \cs_show:N \current@color
    \color_select:n { spotA }
    \cs_show:N \current@color
  }

\TEST { Exporting~colors~in~raw~format }
  {
    \color_export:nnN { blue } { raw } \l_tmpa_tl
    \tl_show:N \l_tmpa_tl
    \color_export:nnN { blue!50!red } { raw } \l_tmpa_tl
    \tl_show:N \l_tmpa_tl
    \color_export:nnN { cyan } { raw } \l_tmpa_tl
    \tl_show:N \l_tmpa_tl
    \color_export:nnnN { gray } { 0.6 } { raw } \l_tmpa_tl
    \tl_show:N \l_tmpa_tl
    \color_export:nnN { spotA } { raw } \l_tmpa_tl
    \tl_show:N \l_tmpa_tl
  }

\END
